{
  "name": "protoloop",
  "version": "0.1.0",
  "description": "Protoloop — Agentic CAD / 3D model studio. Design parametric 3D models by chatting with Claude.",
  "author": "Protoloop",
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:engines": "node --import tsx scripts/test-engines.mts",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@jscad/modeling": "^2.12.4",
    "@jscad/stl-serializer": "^2.1.6",
    "chokidar": "^3.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "framer-motion": "^11.13.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "three": "^0.169.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "zustand": "^5.0.1"
  }
}
